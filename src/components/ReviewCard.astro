---
import { BlogPost } from '../types';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

// Determine color theme based on category
const getCategoryColor = (category: string) => {
  switch (category) {
    case 'Tecnologia':
      return 'text-amber-600 bg-amber-50';
    case 'Casa & Cozinha':
      return 'text-orange-600 bg-orange-50';
    case 'Games':
      return 'text-blue-600 bg-blue-50';
    case 'Esportes':
      return 'text-red-600 bg-red-50';
    default:
      return 'text-gray-600 bg-gray-50';
  }
};
---

<article 
  data-no-edit
  class="bg-white rounded-2xl border border-gray-100 hover:border-amber-200 shadow-xs hover:shadow-md transition-all duration-300 cursor-pointer flex flex-col h-full group"
  onclick={`window.location.href='/blog/${post.slug}'`}
>
  {/* Post Thumbnail */}
  <div class="relative aspect-video w-full overflow-hidden rounded-t-2xl bg-gray-50">
    <img
      src={post.image}
      alt={post.title}
      referrerPolicy="no-referrer"
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute top-3 left-3">
      <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-bold tracking-wide uppercase shadow-2xs ${getCategoryColor(post.category)}`}>
        {post.category}
      </span>
    </div>
  </div>

  {/* Post Content */}
  <div class="p-5 flex flex-col flex-grow">
    {/* Metadata */}
    <div class="flex items-center space-x-3 text-xs text-gray-400 font-medium mb-2">
      <span>{post.readTime} de leitura</span>
      <span>•</span>
      <span>{post.date}</span>
    </div>

    {/* Title */}
    <h3 class="font-sans font-bold text-base md:text-lg text-gray-900 leading-snug tracking-tight mb-2 group-hover:text-amber-600 transition-colors">
      {post.title}
    </h3>

    {/* Description */}
    <p class="text-gray-500 text-sm leading-relaxed mb-6 line-clamp-3">
      {post.description}
    </p>

    {/* Footer info: Author & Navigation */}
    <div class="mt-auto pt-4 border-t border-gray-50 flex items-center justify-between">
      <div class="flex items-center space-x-2.5">
        <img
          src={post.author.avatar}
          alt={post.author.name}
          referrerPolicy="no-referrer"
          class="w-8 h-8 rounded-full object-cover ring-2 ring-gray-100"
        />
        <div>
          <span class="block text-xs font-semibold text-gray-900 leading-none">
            {post.author.name}
          </span>
          <span class="block text-[10px] text-gray-400 mt-0.5 leading-none">
            {post.author.role}
          </span>
        </div>
      </div>
      <div class="w-7 h-7 rounded-full bg-gray-50 group-hover:bg-amber-50 flex items-center justify-center transition-colors">
        <svg class="w-4 h-4 text-gray-400 group-hover:text-amber-500 transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
      </div>
    </div>
  </div>
</article>
