---
import Layout from '../layouts/Layout.astro';
import ReviewCard from '../components/ReviewCard.astro';
import { blogPosts, categories } from '../data/posts';
---

<Layout title="Explorar Categorias" currentPath="/categorias">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-12 min-h-screen text-left">
    {/* Header section */}
    <div class="space-y-3">
      <h1 class="font-sans font-bold text-3xl md:text-4xl text-gray-900 tracking-tight flex items-center space-x-2">
        <svg class="w-8 h-8 text-amber-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
        </svg>
        <span>Explorar por Categoria</span>
      </h1>
      <p class="text-gray-500 text-sm md:text-base max-w-2xl">
        Selecione um segmento abaixo para ler análises técnicas focadas e encontrar os melhores aparelhos e equipamentos avaliados pela nossa equipe.
      </p>
    </div>

    {/* Grid of Category selector cards */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {/* "Todas" card */}
      <div
        id="category-all"
        data-slug="all"
        class="category-btn cursor-pointer rounded-2xl p-6 border transition-all flex items-center space-x-4 border-amber-500 bg-amber-50/50 shadow-xs"
      >
        <div class="category-icon-wrapper w-12 h-12 rounded-xl flex items-center justify-center shrink-0 bg-amber-500 text-white">
          <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
          </svg>
        </div>
        <div>
          <h3 class="font-sans font-bold text-sm text-gray-900 leading-none">Todas</h3>
          <span class="block text-[11px] text-gray-400 mt-1.5 font-medium">
            {blogPosts.length} análises completas
          </span>
        </div>
      </div>

      {/* Real categories from mock data */}
      {categories.map((category) => {
        const categoryCount = blogPosts.filter(p => p.category.toLowerCase() === category.name.toLowerCase()).length;
        
        return (
          <div
            data-slug={category.slug}
            data-name={category.name}
            data-desc={category.description}
            class="category-btn cursor-pointer rounded-2xl p-6 border transition-all flex items-center space-x-4 border-gray-100 bg-white hover:border-amber-200 hover:shadow-xs"
          >
            <div class="category-icon-wrapper w-12 h-12 rounded-xl flex items-center justify-center shrink-0 bg-gray-100 text-gray-600">
              {category.iconName === 'Laptop' && (
                <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25" />
                </svg>
              )}
              {category.iconName === 'Home' && (
                <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                </svg>
              )}
              {category.iconName === 'Gamepad2' && (
                <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                </svg>
              )}
              {category.iconName === 'Flame' && (
                <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" />
                </svg>
              )}
            </div>
            <div>
              <h3 class="font-sans font-bold text-sm text-gray-900 leading-none">{category.name}</h3>
              <span class="block text-[11px] text-gray-400 mt-1.5 font-medium">
                {categoryCount} análises
              </span>
            </div>
          </div>
        );
      })}
    </div>

    {/* Dynamic Banner block */}
    <div id="category-banner" class="hidden bg-gradient-to-r from-amber-500/10 to-orange-500/10 rounded-2xl p-6 sm:p-8 border border-amber-200/40 text-left space-y-2">
      <span id="banner-tag" class="inline-block text-[10px] font-bold text-amber-700 bg-amber-100 px-2.5 py-1 rounded-full uppercase">
        Navegando em
      </span>
      <h2 id="banner-title" class="font-sans font-bold text-xl text-gray-900">
        Análises e Guias
      </h2>
      <p id="banner-desc" class="text-gray-500 text-sm max-w-3xl leading-relaxed">
        Descrição da categoria
      </p>
    </div>

    {/* Grid of results */}
    <div class="space-y-6 pt-4">
      <h3 id="grid-header" class="font-sans font-bold text-lg text-gray-900 border-b border-gray-100 pb-3">
        Todas as nossas análises de produtos ({blogPosts.length})
      </h3>

      <div id="empty-state" class="hidden text-center py-20 bg-white rounded-3xl border border-gray-100 p-8">
        <p class="text-gray-400 text-sm">Sem análises disponíveis nesta categoria temporariamente.</p>
      </div>

      <div id="posts-grid" data-no-edit class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {blogPosts.map((post) => (
          <div class="post-card-wrapper" data-category={post.category.toLowerCase()}>
            <ReviewCard post={post} />
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>

<script>
  // Client side filtering logic
  const buttons = document.querySelectorAll('.category-btn');
  const wrappers = document.querySelectorAll('.post-card-wrapper');
  const banner = document.getElementById('category-banner');
  const bannerTag = document.getElementById('banner-tag');
  const bannerTitle = document.getElementById('banner-title');
  const bannerDesc = document.getElementById('banner-desc');
  const gridHeader = document.getElementById('grid-header');
  const emptyState = document.getElementById('empty-state');
  const postsGrid = document.getElementById('posts-grid');

  // Handle URL query parameters on load if present
  const urlParams = new URLSearchParams(window.location.search);
  const initialCategory = urlParams.get('categoria');

  const filterCategory = (slug: string, name?: string, desc?: string) => {
    // 1. Update active styling
    buttons.forEach(btn => {
      const btnSlug = btn.getAttribute('data-slug');
      const iconWrapper = btn.querySelector('.category-icon-wrapper');
      
      if (btnSlug === slug) {
        btn.classList.remove('border-gray-100', 'bg-white', 'hover:border-amber-200', 'hover:shadow-xs');
        btn.classList.add('border-amber-500', 'bg-amber-50/50', 'shadow-xs');
        if (iconWrapper) {
          iconWrapper.classList.remove('bg-gray-100', 'text-gray-600');
          iconWrapper.classList.add('bg-amber-500', 'text-white');
        }
      } else {
        btn.classList.add('border-gray-100', 'bg-white', 'hover:border-amber-200', 'hover:shadow-xs');
        btn.classList.remove('border-amber-500', 'bg-amber-50/50', 'shadow-xs');
        if (iconWrapper) {
          iconWrapper.classList.add('bg-gray-100', 'text-gray-600');
          iconWrapper.classList.remove('bg-amber-500', 'text-white');
        }
      }
    });

    // 2. Filter posts
    let visibleCount = 0;
    wrappers.forEach(wrap => {
      const cardCategory = wrap.getAttribute('data-category');
      
      if (slug === 'all' || cardCategory === name?.toLowerCase() || cardCategory === slug) {
        (wrap as HTMLElement).style.display = 'block';
        visibleCount++;
      } else {
        (wrap as HTMLElement).style.display = 'none';
      }
    });

    // 3. Update Banner
    if (slug === 'all' || !name) {
      if (banner) banner.classList.add('hidden');
      if (gridHeader) gridHeader.textContent = `Todas as nossas análises de produtos (${visibleCount})`;
    } else {
      if (banner) banner.classList.remove('hidden');
      if (bannerTag) bannerTag.textContent = `Navegando em ${name}`;
      if (bannerTitle) bannerTitle.textContent = `Análises e Guias de ${name}`;
      if (bannerDesc) bannerDesc.textContent = desc || '';
      if (gridHeader) gridHeader.textContent = `Reviews na categoria: ${name} (${visibleCount})`;
    }

    // 4. Update empty state
    if (visibleCount === 0) {
      if (emptyState) emptyState.classList.remove('hidden');
      if (postsGrid) postsGrid.classList.add('hidden');
    } else {
      if (emptyState) emptyState.classList.add('hidden');
      if (postsGrid) postsGrid.classList.remove('hidden');
    }
  };

  // Click handler
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const slug = btn.getAttribute('data-slug') || 'all';
      const name = btn.getAttribute('data-name') || undefined;
      const desc = btn.getAttribute('data-desc') || undefined;
      filterCategory(slug, name, desc);
      
      // Update browser URL query param without refreshing
      const newUrl = new URL(window.location.href);
      if (slug === 'all') {
        newUrl.searchParams.delete('categoria');
      } else {
        newUrl.searchParams.set('categoria', slug);
      }
      window.history.pushState({}, '', newUrl);
    });
  });

  // Apply initial filter if query param is set
  if (initialCategory) {
    const activeBtn = Array.from(buttons).find(b => b.getAttribute('data-slug') === initialCategory);
    if (activeBtn) {
      const name = activeBtn.getAttribute('data-name') || undefined;
      const desc = activeBtn.getAttribute('data-desc') || undefined;
      filterCategory(initialCategory, name, desc);
    }
  }
</script>
