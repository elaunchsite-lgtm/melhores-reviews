---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/posts';

export async function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const relatedPosts = blogPosts
  .filter(p => p.category === post.category && p.slug !== post.slug)
  .slice(0, 3);

const finalRelated = relatedPosts.length > 0
  ? relatedPosts
  : blogPosts.filter(p => p.slug !== post.slug).slice(0, 3);
---

<Layout title={post.title} description={post.description} currentPath={`/blog/${post.slug}`}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-12 pb-20">
    <a href="/blog" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-gray-600 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Voltar para análises
    </a>

    <header class="space-y-6">
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center gap-1 rounded-full bg-amber-100 text-amber-800 px-3 py-1 text-xs font-semibold">
          {post.category}
        </span>
        <span class="text-xs text-gray-400">{post.readTime} de leitura</span>
      </div>

      <div>
        <span class="text-xs text-gray-400">{post.date}</span>
      </div>

      <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 leading-tight">
        {post.title}
      </h1>
      <p class="text-lg text-gray-500 leading-relaxed">
        {post.description}
      </p>

      {post.author && typeof post.author === 'object' ? (
        <div class="flex items-center space-x-3.5 p-4 bg-gray-50 rounded-2xl border border-gray-100">
          <img src={post.author.avatar} alt={post.author.name} referrerPolicy="no-referrer" class="w-11 h-11 rounded-full object-cover ring-2 ring-amber-100" />
          <div>
            <span class="block text-sm font-bold text-gray-900">{post.author.name}</span>
            <span class="block text-xs text-gray-500">{post.author.role} • Analista Técnico Oficial</span>
          </div>
        </div>
      ) : post.author ? (
        <div class="flex items-center space-x-3 p-4 bg-gray-50 rounded-2xl border border-gray-100">
          <div class="w-11 h-11 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center font-bold text-sm uppercase">{String(post.author)[0]}</div>
          <div><span class="block text-sm font-bold text-gray-900">{post.author}</span></div>
        </div>
      ) : null}
    </header>

    {post.image && (
      <div class="relative aspect-video w-full rounded-3xl overflow-hidden bg-gray-100 shadow-xs border border-gray-100">
        <img src={post.image} alt={post.title} referrerPolicy="no-referrer" class="w-full h-full object-cover" />
      </div>
    )}

    {post.specs && (
      <section class="bg-white rounded-3xl border border-gray-100 p-6 sm:p-8 shadow-xs space-y-6">
        <h2 class="text-xl font-bold text-gray-900">📊 Ficha Técnica & Classificação</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <tbody class="divide-y divide-gray-100">
              {post.specs.map((spec) => (
                <tr><td class="py-3 pr-6 font-medium text-gray-600">{spec.label}</td><td class="py-3 text-gray-900">{spec.value}</td></tr>
              ))}
              <tr>
                <td class="py-3 pr-6 font-medium text-gray-600">⭐ Nota Geral</td>
                <td class="py-3">
                  <div class="flex items-center gap-2">
                    <div class="flex">{Array.from({length:5}).map((_,star) => <svg class={`w-5 h-5 ${star <= Math.round(post.rating) ? 'text-amber-500 fill-amber-400' : 'text-gray-200'}`} viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}</div>
                    <span class="text-3xl font-extrabold text-gray-900">{post.rating}</span>
                    <span class="text-xs text-gray-400">/10</span>
                  </div>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    )}

    {post.sections && post.sections.map((section) => (
      <section class="bg-white rounded-3xl border border-gray-100 p-6 sm:p-8 shadow-xs">
        <h2 class="text-xl font-bold text-gray-900 mb-4">{section.heading}</h2>
        <div class="prose prose-gray max-w-none" set:html={section.content} />
      </section>
    ))}

    {post.pros && post.cons && (
      <div class="grid sm:grid-cols-2 gap-6">
        <div class="bg-emerald-50 border border-emerald-100 rounded-3xl p-6">
          <h3 class="font-bold text-emerald-800 mb-3">✅ Prós / Vantagens</h3>
          <ul class="space-y-2">{post.pros.map((pro) => <li class="flex items-start gap-2 text-sm text-emerald-700"><span class="mt-0.5">✓</span> {pro}</li>)}</ul>
        </div>
        <div class="bg-red-50 border border-red-100 rounded-3xl p-6">
          <h3 class="font-bold text-red-800 mb-3">❌ Contras / Desvantagens</h3>
          <ul class="space-y-2">{post.cons.map((con) => <li class="flex items-start gap-2 text-sm text-red-700"><span class="mt-0.5">✗</span> {con}</li>)}</ul>
        </div>
      </div>
    )}

    {post.affiliateLink && (
      <div class="bg-amber-50 border border-amber-200 rounded-3xl p-6 text-center">
        <h3 class="font-bold text-amber-900 mb-2">🛒 Compre o {post.title.split(':')[0]} com Desconto Especial</h3>
        <a href={post.affiliateLink} target="_blank" rel="nofollow noopener sponsored" class="inline-flex items-center gap-2 bg-amber-500 text-white px-6 py-3 rounded-full font-bold hover:bg-amber-600 transition-colors">
          Ver Menor Preço na {post.affiliateStore}
        </a>
      </div>
    )}

    {finalRelated.length > 0 && (
      <section class="border-t border-gray-100 pt-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">🤩 Análises Relacionadas</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {finalRelated.map(rp => (
            <a href={`/blog/${rp.slug}`} class="group bg-white border border-gray-100 rounded-2xl p-5 hover:shadow-md transition-shadow">
              <h3 class="font-semibold text-gray-900 group-hover:text-amber-500 transition-colors">{rp.title}</h3>
              <div class="flex items-center gap-2 mt-2">
                <span class="text-xs text-gray-400">{rp.category}</span>
                <span class="text-xs text-amber-500">★ {rp.rating}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</Layout>
