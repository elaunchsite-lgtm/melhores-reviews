---
import Layout from '../../layouts/Layout.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import { blogPosts } from '../../data/posts';

const availableCategories = ['Todas', ...Array.from(new Set(blogPosts.map(p => p.category)))];
---

<Layout title="Blog de Reviews" currentPath="/blog">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-2 font-sans">Blog de Reviews</h1>
    <p class="text-gray-500 mb-8">Análises detalhadas e comparativos dos melhores produtos</p>
    <div class="flex flex-wrap gap-2 mb-8">
      {availableCategories.map(cat => (
        <button class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${cat === 'Todas' ? 'bg-amber-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`}>
          {cat}
        </button>
      ))}
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {blogPosts.map(post => (
        <a href={`/blog/${post.slug}`} class="group">
          <ReviewCard post={post} />
        </a>
      ))}
    </div>
  </section>
</Layout>
