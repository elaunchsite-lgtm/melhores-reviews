---
import { config } from '../lib/config';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../index.css';

interface Props {
  title: string;
  description?: string;
  currentPath?: string;
}

const { title, description = config.siteDescription, currentPath = '/' } = Astro.props;
const siteUrl = config.siteUrl || config.domain ? `https://${config.domain}` : Astro.site?.href || "http://localhost:4321";
const pluginsHead = config._plugins?.head?.replace(/SITE_URL/g, siteUrl) || "";
const pluginsBody = config._plugins?.body?.replace(/SITE_URL/g, siteUrl) || "";
const primary = config.primaryColor || "#f59e0b";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | {config.siteName}</title>
    <meta name="description" content={description} />
    <style>:root { --primary: ${primary}; }</style>
    {config.favicon && <link rel="icon" href={config.favicon} />}
    {pluginsHead && <Fragment set:html={pluginsHead} />}
  </head>
  <body class="min-h-screen flex flex-col bg-[#FAF9F5] text-gray-900 selection:bg-amber-500 selection:text-white">
    <Navbar currentPath={currentPath} navItems={config.navigation} siteName={config.siteName} />
    <main id="main-content" class="flex-grow">
      <slot />
    </main>
    <Footer siteName={config.siteName} description={config.siteDescription} />
    {pluginsBody && <Fragment set:html={pluginsBody} />}
  </body>
</html>
